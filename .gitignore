.DS_Store
.env
.env.local
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
.next/
dist/
build/
coverage/
*.log
frontend/tsconfig.tsbuildinfo

# Runtime storage — may contain personal/tenant data
storage/uploads/*
storage/exports/*
storage/generated/*
storage/tenant_clones/*

# Tenant-specific content: ignore all, but keep tenant-1 demo templates
storage/document_template_parts/tenant-*/
!storage/document_template_parts/tenant-1/
!storage/document_template_parts/tenant-1/**
storage/document_templates/tenant-*/
!storage/document_templates/tenant-1/
!storage/document_templates/tenant-1/**

# Protocol snapshots are generated at runtime (may contain user data)
storage/document_template_snapshots/

# Keep placeholder files so directories exist after clone
!storage/uploads/.gitkeep
!storage/exports/.gitkeep

# Traefik TLS state
infra/traefik/letsencrypt/acme.json

# Generated per-tenant Traefik router config (traefik_config_service.py)
infra/traefik/dynamic/tenant-domains.yml

# DB backups and abgabebox uploads — real user data, never committed
backups/
storage/abgabebox-uploads/*
