POSTGRES_DB=hocx
POSTGRES_USER=hocx
POSTGRES_PASSWORD=hocx
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://hocx:hocx@db:5432/hocx
TRAEFIK_DOMAIN=your-domain.example.com
ACME_EMAIL=your@email.com
# Angezeigt klein auf der Login-Seite. Fuer Dev reicht "dev" - in Test/Prod wird das
# ueber HOCX_VERSION in der jeweiligen .env auf die tatsaechliche Release-Version gesetzt.
HOCX_VERSION=dev
NEXT_PUBLIC_API_URL=https://your-domain.example.com
INTERNAL_API_URL=http://backend:8000
AUTH_SECRET=change-me-to-a-random-32-plus-char-value

# Platform-Admin-Panel (/admin) - eigenes, von AppUser/superadmin getrenntes System.
# INITIAL_ADMIN_EMAIL/PASSWORD bootstrappen nur den allerersten Account (nur wirksam,
# solange die platform_admin-Tabelle leer ist); weitere Admins verwaltet man im Panel.
ADMIN_AUTH_SECRET=change-me-to-a-different-random-32-plus-char-value
INITIAL_ADMIN_EMAIL=admin@your-domain.example.com
INITIAL_ADMIN_PASSWORD=change-me-before-first-deploy

# Abgabebox (oeffentliche Upload-Box ohne Login, siehe abgabebox-backend/abgabebox-frontend)
TRAEFIK_ABGABEBOX_DOMAIN=abgabe.your-domain.example.com
ABGABEBOX_DB_PASSWORD=change-me-to-a-random-32-plus-char-value
ABGABEBOX_DATABASE_URL=postgresql+psycopg://hocx_abgabebox:change-me-to-a-random-32-plus-char-value@db:5432/hocx
FRIENDLY_CAPTCHA_SITEKEY=your-friendly-captcha-sitekey
FRIENDLY_CAPTCHA_API_KEY=your-friendly-captcha-api-key
