# Prod-Umgebung (docker-compose.release.yml + docker-compose.clamav.yml +
# docker-compose.traefik.yml). Kopie als .env.prod anlegen, echte Werte eintragen -
# NIE committen.

# Release-Version, die auf diesem Server laufen soll - immer eine konkrete Version
# pinnen, nie "latest" (siehe RUNBOOK.md).
HOCX_VERSION=v1.0.0
# GitHub-Namespace (kleingeschrieben) der Container-Images, z.B. frissbrot
GHCR_NAMESPACE=your-github-org-lowercase
# Praefix fuer Traefik-Router-/Service-Namen. Auf Prod (eigener Traefik, keine
# Kollisionsgefahr) kann das Default "hocx" bleiben - einfach nicht setzen.
# ROUTER_PREFIX=hocx

POSTGRES_DB=hocx
POSTGRES_USER=hocx
POSTGRES_PASSWORD=change-me-to-a-random-32-plus-char-value
DATABASE_URL=postgresql+psycopg://hocx:change-me-to-a-random-32-plus-char-value@db:5432/hocx
TRAEFIK_DOMAIN=hocx.ch
ACME_EMAIL=your@email.com
NEXT_PUBLIC_API_URL=https://hocx.ch
INTERNAL_API_URL=http://backend:8000
AUTH_SECRET=change-me-to-a-random-32-plus-char-value

# Platform-Admin-Panel (/admin) - eigenes, von AppUser/superadmin getrenntes System.
# INITIAL_ADMIN_EMAIL/PASSWORD bootstrappen nur den allerersten Account (nur wirksam,
# solange die platform_admin-Tabelle leer ist); weitere Admins verwaltet man im Panel.
ADMIN_AUTH_SECRET=change-me-to-a-different-random-32-plus-char-value
INITIAL_ADMIN_EMAIL=admin@hocx.ch
INITIAL_ADMIN_PASSWORD=change-me-before-first-deploy

# Abgabebox (oeffentliche Upload-Box ohne Login, siehe abgabebox-backend/abgabebox-frontend)
TRAEFIK_ABGABEBOX_DOMAIN=abgabe.hocx.ch
ABGABEBOX_DB_PASSWORD=change-me-to-a-random-32-plus-char-value
ABGABEBOX_DATABASE_URL=postgresql+psycopg://hocx_abgabebox:change-me-to-a-random-32-plus-char-value@db:5432/hocx
FRIENDLY_CAPTCHA_SITEKEY=your-friendly-captcha-sitekey
FRIENDLY_CAPTCHA_API_KEY=your-friendly-captcha-api-key
